# Configuration untuk AI CENTER UB DGX UB
# Copy ke config.yaml di AI Center

# Multi-Device Configuration
device:
  device_id: "aicenter"  # Unique ID untuk AI Center
  total_devices: 2       # Total: Laptop + AI Center

# Evaluation Configuration
evaluation:
  metrics:
    - "fitness"
    - "runtime"
    - "convergence"
    - "diversity"
    - "solution_quality"
  n_runs: 5
  save_results: true
  save_plots: true
  save_routes: true
  save_convergence_history: true
  parallel: true  # Enable parallel execution
  n_jobs: 60      # 60 workers untuk AI Center (256 cores, leave some for OS)
  parallel_methods: true  # Enable parallel execution untuk multiple methods
  # Dengan parallel_methods: true, semua tasks (methods × runs) dieksekusi dalam satu pool
  # Jadi bisa 60 tasks sekaligus (mix methods dan runs) - sangat efisien untuk AI Center!

# ... rest sama dengan config.yaml ...

