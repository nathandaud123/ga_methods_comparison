# Configuration untuk AI CENTER UB DGX UB
# Copy ke config.yaml di AI Center

# Multi-Device Configuration
device:
  device_id: "aicenter"  # Unique ID untuk AI Center
  total_devices: 2       # Total: Laptop + AI Center

# Evaluation Configuration
evaluation:
  metrics:
    - "fitness"
    - "runtime"
    - "convergence"
    - "diversity"
    - "solution_quality"
  n_runs: 5
  save_results: true
  save_plots: true
  save_routes: true
  save_convergence_history: true
  parallel: true  # Gunakan SEMUA core AI Center
  n_jobs: 250     # Set manual: 256 cores - 6 cores untuk OS/system (leave some free)
  # Atau gunakan null untuk auto-detect, tapi lebih baik set manual untuk optimal
  # n_jobs: null  # Auto-detect (akan pakai CPU_COUNT - 1)

# ... rest sama dengan config.yaml ...

