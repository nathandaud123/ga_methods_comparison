# Configuration untuk LAPTOP
# Copy ke config.yaml di laptop

# Multi-Device Configuration
device:
  device_id: "laptop"  # Unique ID untuk laptop
  total_devices: 2     # Total: Laptop + AI Center

# Evaluation Configuration
evaluation:
  metrics:
    - "fitness"
    - "runtime"
    - "convergence"
    - "diversity"
    - "solution_quality"
  n_runs: 5
  save_results: true
  save_plots: true
  save_routes: true
  save_convergence_history: true
  parallel: true  # Gunakan semua core laptop
  n_jobs: null    # Auto-detect (akan pakai CPU_COUNT - 1)

# ... rest sama dengan config.yaml ...

